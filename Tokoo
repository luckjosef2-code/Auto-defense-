local function createToggle(text, yPos, callback)
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(0.9,0,0,34)
	bg.Position = UDim2.new(0.05,0,0,yPos)
	bg.BackgroundColor3 = Color3.fromRGB(25,30,40)
