-- UPDATE FPS + PING WITH COLORS
local last = tick()

RunService.RenderStepped:Connect(function()
	local fps = math.floor(1 / (tick() - last))
	last = tick()

	local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())

	-- FPS Color
	local fpsColor = Color3.fromRGB(0,255,0)
	if fps < 40 then
		fpsColor = Color3.fromRGB(255,0,0)
	elseif fps < 60 then
		fpsColor = Color3.fromRGB(255,170,0)
	end

	-- Ping Color
	local pingColor = Color3.fromRGB(0,255,0)
	if ping > 150 then
		pingColor = Color3.fromRGB(255,0,0)
	elseif ping > 80 then
		pingColor = Color3.fromRGB(255,170,0)
	end

	info.Text = "FPS: "..fps.." | Ping: "..ping
	info.TextColor3 = fpsColor:Lerp(pingColor, 0.5)
end)

