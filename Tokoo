	bg.Parent = main
	Instance.new("UICorner", bg).CornerRadius = UDim.new(0,10)

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.6,0,1,0)
	lbl.BackgroundTransparency = 1
	lbl.Text = text
	lbl.TextColor3 = Color3.fromRGB(220,220,255)
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 14
	lbl.TextStrokeTransparency = 0.6
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = bg

	local btn = Instance.new("Frame")
	btn.Size = UDim2.new(0,40,0,20)
	btn.Position = UDim2.new(1,-48,0.5,-10)
	btn.BackgroundColor3 = Color3.fromRGB(50,50,60)
	btn.Parent = bg
	Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)

	local dot = Instance.new("Frame")
	dot.Size = UDim2.new(0,18,0,18)
	dot.Position = UDim2.new(0,1,0,1)
	dot.BackgroundColor3 = Color3.fromRGB(120,120,140)
	dot.Parent = btn
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)

	local state = false
	toggleStates[text] = false

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 
		or input.UserInputType == Enum.UserInputType.Touch then
			
			state = not state
			toggleStates[text] = state

			if state then
				dot:TweenPosition(UDim2.new(1,-19,0,1),"Out","Quad",0.2,true)
				dot.BackgroundColor3 = Color3.fromRGB(0,170,255)
			else
				dot:TweenPosition(UDim2.new(0,1,0,1),"Out","Quad",0.2,true)
				dot.BackgroundColor3 = Color3.fromRGB(120,120,140)
			end

			if callback then
				callback(state)
			end
		end
	end)

	table.insert(toggles, bg)
end

